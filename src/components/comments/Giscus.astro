---
import { giscusConfig } from "../../config";

interface Props {
	class?: string;
}

const className = Astro.props.class;
---

{giscusConfig.enable && (
    <div id="giscus-container" class:list={[className, "w-full"]}>
        <div class="giscus"></div>
    </div>
)}

<script>
    import { loadGiscus } from "../../utils/giscus-utils";

    function initGiscus() {
        // Wait for the .giscus container to be in the DOM
        const container = document.querySelector(".giscus");
        if (container) {
            loadGiscus();
        }
    }

    // Handle initial page load
    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initGiscus);
    } else {
        initGiscus();
    }

    // Handle Swup page transitions
    const setupSwup = () => {
        window.swup.hooks.on("page:view", initGiscus);
        window.swup.hooks.on("content:replace", () => {
            // Remove old giscus iframe before content replacement
            const oldFrame = document.querySelector(".giscus-frame");
            if (oldFrame) {
                oldFrame.remove();
            }
        }, { before: true });
    };

    if (window.swup) {
        setupSwup();
    } else {
        document.addEventListener("swup:enable", setupSwup);
    }
</script>